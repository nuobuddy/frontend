# Backend API base URL
# Used by the Axios client (src/lib/axios.ts) to prefix all requests.
# Set this to the full backend URL in all environments.
# Example (local dev):  VITE_API_BASE=http://localhost:3000
# Example (production): VITE_API_BASE=https://api.example.com
VITE_API_BASE=http://localhost:3000
